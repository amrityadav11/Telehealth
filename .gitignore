# ── Dependencies ──────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Build outputs ─────────────────────────────────────────────────────────
frontend/build/
frontend/.cache/

# ── Environment files (NEVER commit secrets) ──────────────────────────────
.env
backend/.env
frontend/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/

# ── Uploads (user-generated content, not source code) ─────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── Misc ──────────────────────────────────────────────────────────────────
*.pem
coverage/
.nyc_output/
